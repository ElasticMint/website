<![endif]-->
<!--[if IE 7]>
<html id="ie7" lang="en-GB">
<![endif]-->
<!--[if IE 8]>
<html id="ie8" lang="en-GB">
<![endif]-->
<!--[if !(IE 6) | !(IE 7) | !(IE 8)  ]><!-->
<html lang="en-GB">
<!--<![endif]-->


<meta http-equiv="content-type" content="text/html;charset=UTF-8" />
<head>
<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-9D70PLKZQD"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-9D70PLKZQD');
</script>




<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width" />
<title>{{ title }}</title>
<link rel="profile" href="http://gmpg.org/xfn/11" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link rel="preload" href="/wp-content/themes/ElasticMint/fonts/intro-regular-webfont.woff2" as="font" type="font/woff2" crossorigin />
<link rel="preload" href="/wp-content/themes/ElasticMint/fonts/intro-light-webfont.woff2" as="font" type="font/woff2" crossorigin />
<link rel="stylesheet" type="text/css" media="all" href="/wp-content/themes/ElasticMint/style.css" />
<!--[if lt IE 9]>
<script src="https://www.elasticmint.com/wp-content/themes/ElasticMint/js/html5.js" type="text/javascript"></script>
<![endif]-->
<meta name='robots' content='index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1' />
	<style>img:is([sizes="auto" i], [sizes^="auto," i]) { contain-intrinsic-size: 3000px 1500px }</style>


	<meta name="description" content="{{ description }}" />
	<link rel="canonical" href="{{ canonical }}" />
	<meta property="og:locale" content="en_GB" />
	<meta property="og:type" content="{{ ogType or 'website' }}" />
	<meta property="og:title" content="{{ ogTitle or title }}" />
	<meta property="og:description" content="{{ ogDescription or description }}" />
	<meta property="og:url" content="{{ ogUrl }}" />
	<meta property="og:site_name" content="Elastic Mint" />
{%- if ogImage %}
	<meta property="og:image" content="{{ ogImage }}" />
{%- endif %}
{%- if ogImageWidth %}
	<meta property="og:image:width" content="{{ ogImageWidth }}" />
{%- endif %}
{%- if ogImageHeight %}
	<meta property="og:image:height" content="{{ ogImageHeight }}" />
{%- endif %}
{%- if ogImageType %}
	<meta property="og:image:type" content="{{ ogImageType }}" />
{%- endif %}
{%- if articlePublishedTime %}
	<meta property="article:published_time" content="{{ articlePublishedTime }}" />
{%- endif %}
{%- if articleModifiedTime %}
	<meta property="article:modified_time" content="{{ articleModifiedTime }}" />
{%- endif %}
{%- if author %}
	<meta name="author" content="{{ author }}" />
{%- endif %}
	<meta name="twitter:card" content="summary_large_image" />
	<meta name="twitter:site" content="@elasticmint" />
{%- if twitterCreator %}
	<meta name="twitter:creator" content="{{ twitterCreator }}" />
{%- endif %}
{%- if twitterLabel1 %}
	<meta name="twitter:label1" content="{{ twitterLabel1 }}" />
	<meta name="twitter:data1" content="{{ twitterData1 }}" />
{%- endif %}
{%- if twitterLabel2 %}
	<meta name="twitter:label2" content="{{ twitterLabel2 }}" />
	<meta name="twitter:data2" content="{{ twitterData2 }}" />
{%- endif %}
{%- if schemaGraph %}
	<script type="application/ld+json" class="yoast-schema-graph">{{ schemaGraph | safe }}</script>
{%- endif %}


<script type="text/javascript" src="https://ajax.googleapis.com/ajax/libs/jquery/1.11.2/jquery.min.js" id="jquery-js"></script>
<style>.single-case-study .wrap-title .wrap-content h4, .news-item .over-date, .page-template-CaseStudies .over-date {
	display: none;
}</style>
		<link rel="shortcut icon" href="/wp-content/themes/ElasticMint/favicon.png" />
<link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
<link rel="stylesheet" href="https://unpkg.com/simplebar@6.3.2/dist/simplebar.css" />
</head>

<body class="{{ bodyClass }}">

{% include "header.njk" %}

<div id="closemenu" class="close-menu-overlay"></div>

{% include "nav-mobile.njk" %}

<div id="site-container" class="row container">

{{ content | safe }}

{% include "footer.njk" %}
</div>
<script src="https://unpkg.com/simplebar@6.3.2/dist/simplebar.min.js"></script>
{%- if usesCanvas %}
<script src="https://cdnjs.cloudflare.com/ajax/libs/paper.js/0.12.11/paper-full.min.js"></script>
{%- endif %}
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.6.0/gsap.min.js"></script>
<script src="/wp-content/themes/ElasticMint/js/anime.min.js"></script>
<script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
<script>
(function(){var OriginalSimpleBar=window.SimpleBar;window.SimpleBar=function(el,opts){if(!el)return null;return new OriginalSimpleBar(el,opts);};})();
</script>
<script src="/wp-content/themes/ElasticMint/js/all.js"></script>
</body>


</html>
