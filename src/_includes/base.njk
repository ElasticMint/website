(function(){var OriginalSimpleBar=window.SimpleBar;window.SimpleBar=function(el,opts){if(!el)return null;return new OriginalSimpleBar(el,opts);};})();
</script>
<script src="/wp-content/themes/ElasticMint/js/all.js"></script>
<script>
(function() {
	if (!window.__cookieConsent) {
		var b = document.getElementById('cookie-consent');
		if (b) b.removeAttribute('hidden');
	}
	var accept = document.getElementById('cookie-accept');
	var reject = document.getElementById('cookie-reject');
	function dismiss() {
		var b = document.getElementById('cookie-consent');
		if (b) b.setAttribute('hidden', '');
	}
	if (accept) accept.addEventListener('click', function() {
		try { localStorage.setItem('cookie_consent', 'accepted'); } catch(e) {}
		if (window.__loadGA) window.__loadGA();
		if (window.__loadCS) window.__loadCS();
		dismiss();
	});
	if (reject) reject.addEventListener('click', function() {
		try { localStorage.setItem('cookie_consent', 'rejected'); } catch(e) {}
		dismiss();
	});
})();
</script>
</body>


